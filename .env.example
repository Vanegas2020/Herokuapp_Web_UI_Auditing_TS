# ─────────────────────────────────────────────────────────────
# Auditing Project — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── Playwright Runtime ───────────────────────────────────────
# Set HEADED=true to see the browser during audit runs (useful for debugging)
HEADED=false

# Slow down each Playwright action by N milliseconds (0 = disabled)
SLOWMO=0

# Set CI=true on CI environments (disables video retain-on-failure)
CI=false

# Number of parallel workers
# Default is 1 for Auditing to prevent resource exhaustion.
# Set to 'auto' for Playwright default behavior or an integer for specific worker count.
WORKERS=1

# ── Page URL Overrides ───────────────────────────────────────
# Uncomment and set these to override the URL captured during the wizard.
# Useful when your staging/prod URL differs from the recorded URL.

# Login — override URL
# PAGE_URL_LOGIN=https://the-internet.herokuapp.com/login

# ─────────────────────────────────────────────────────────────
